const SCOL={Energy:"#22d3a5",Transport:"#60a5fa","Local Government":"#a78bfa","Professional Services":"#fb923c","Construction/Development":"#f472b6","Business/Industry":"#38bdf8","Environmental/NGO":"#86efac","Community/Residents":"#fde68a","Water/Utilities":"#67e8f9",Academia:"#d1d5db","Individual/Citizen":"#6b7280"};
const PCOL={Supportive:"#22d3a5","Conditional support":"#fb923c",Mixed:"#94a3b8","Raising concerns":"#f87171",Opposed:"#ef4444"};
const SECTORS=["Energy","Transport","Local Government","Professional Services","Construction/Development","Business/Industry","Environmental/NGO","Community/Residents","Water/Utilities","Academia","Individual/Citizen"];
const POSITIONS=["Raising concerns","Conditional support","Mixed","Supportive","Opposed"];
const ISSUES=["Planning delays","Delivery timelines","Agency coordination","Regulatory complexity","Funding/investment","Capacity/skills","Grid connections","Legal reform","Environmental assessment","Climate/sustainability","Public consultation","Housing delivery","Procurement","Investor confidence","Community engagement"];

let activeFilter='all';
let activeIssue=null;


const COVERAGE=[
  {issue:"Planning delays",count:131,covered:true,pillar:"Regulatory Reform",note:"Actions 8, 16, 23"},
  {issue:"Delivery timelines",count:117,covered:true,pillar:"Delivery & Coordination",note:"Actions 17–24"},
  {issue:"Agency coordination",count:52,covered:true,pillar:"Delivery & Coordination",note:"Actions 19, 21"},
  {issue:"Regulatory complexity",count:50,covered:true,pillar:"Regulatory Reform",note:"Actions 9–16"},
  {issue:"Funding/investment",count:35,covered:true,pillar:"Delivery & Coordination",note:"Actions 17, 18"},
  {issue:"Capacity/skills",count:22,covered:false,pillar:null,note:"Not a named pillar or action"},
  {issue:"Grid connections",count:21,covered:false,pillar:null,note:"Not directly addressed"},
  {issue:"Legal reform",count:17,covered:true,pillar:"Legal Reform",note:"Actions 1–7"},
  {issue:"Environmental assessment",count:15,covered:true,pillar:"Legal Reform",note:"Action 4"},
  {issue:"Climate/sustainability",count:14,covered:false,pillar:null,note:"Not a named pillar"},
  {issue:"Housing delivery",count:14,covered:false,pillar:null,note:"Not directly actioned"},
  {issue:"Public consultation",count:14,covered:true,pillar:"Public Acceptance",note:"Actions 28, 29"},
  {issue:"Procurement",count:13,covered:true,pillar:"Delivery & Coordination",note:"Action 25"},
  {issue:"Investor confidence",count:11,covered:true,pillar:"Delivery & Coordination",note:"Actions 17, 18, 20"},
];

function renderCoverage(){
  document.getElementById('coverageList').innerHTML=COVERAGE.map(c=>`
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
      <div style="flex:0 0 130px;font-size:10px;color:${c.covered?'#94a3b8':'#e2e8f0'};font-family:'DM Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.issue}</div>
      <div style="flex:0 0 7px;height:7px;border-radius:50%;background:${c.covered?'#334155':'#f87171'};flex-shrink:0"></div>
      <div style="flex:1;font-size:10px;color:${c.covered?'#334155':'#fb923c'};font-family:'DM Mono',monospace">${c.covered?c.pillar:'Not addressed in Action Plan'}</div>
      <div style="flex:0 0 24px;text-align:right;font-size:10px;color:${c.covered?'#334155':'#f87171'};font-family:'DM Mono',monospace">${c.count}</div>
    </div>`).join('');
}

function getFiltered(){
  return ALL.filter(r=>{
    if(activeFilter==='Organisation'&&r.type!=='Organisation') return false;
    if(activeFilter==='Individual'&&r.type!=='Individual') return false;
    if(SECTORS.includes(activeFilter)&&r.sector!==activeFilter) return false;
    if(activeIssue&&!r.issues.includes(activeIssue)) return false;
    return true;
  });
}

function render(){
  const d=getFiltered();
  const total=d.length;
  document.getElementById('totalNum').textContent=total;

  // Active label
  let lab='All submissions';
  if(activeFilter!=='all') lab=activeFilter;
  if(activeIssue) lab=(activeFilter!=='all'?activeFilter+' · ':'')+activeIssue;
  document.getElementById('activeLabel').textContent=lab;

  const posCounts={};
  POSITIONS.forEach(p=>posCounts[p]=0);
  d.forEach(r=>{posCounts[r.position]=(posCounts[r.position]||0)+1});

  const secCounts={};
  d.forEach(r=>{secCounts[r.sector]=(secCounts[r.sector]||0)+1});

  const issCounts={};
  d.forEach(r=>r.issues.forEach(i=>{issCounts[i]=(issCounts[i]||0)+1}));
  const maxIss=Math.max(...Object.values(issCounts),1);

  // Stats
  document.getElementById('statsGrid').innerHTML=[
    {label:"Raising concerns",val:posCounts["Raising concerns"]||0,col:"#f87171"},
    {label:"Conditional support",val:posCounts["Conditional support"]||0,col:"#fb923c"},
    {label:"Mixed",val:posCounts["Mixed"]||0,col:"#94a3b8"},
    {label:"Supportive",val:posCounts["Supportive"]||0,col:"#22d3a5"},
  ].map(s=>`<div class="stat"><div class="stat-label">${s.label}</div><div class="stat-val" style="color:${s.col}">${s.val}</div><div class="stat-sub">${Math.round(s.val/total*100)}%</div></div>`).join('');

  // Filters
  const fOpts=['all','Organisation','Individual',...SECTORS.filter(s=>(secCounts[s]||activeFilter===s)&&s!=='Individual/Citizen')];
  document.getElementById('filters').innerHTML=fOpts.map((f,i)=>`<button class="fb${activeFilter===f?' on':''}" data-val="${encodeURIComponent(f)}">${f==='all'?'All':f.replace('/Citizen','').replace('/NGO','').replace('/Development','').replace('/Industry','')}</button>`).join('');
  document.getElementById('filters').querySelectorAll('button').forEach(btn=>{btn.onclick=()=>setFilter(decodeURIComponent(btn.dataset.val));});

  // Issues
  const sortedIss=ISSUES.filter(i=>issCounts[i]).sort((a,b)=>(issCounts[b]||0)-(issCounts[a]||0));
  const issHtml=sortedIss.map((iss,i)=>{
    const cnt=issCounts[iss]||0;
    const pct=cnt/maxIss*100;
    const act=activeIssue===iss;
    return `<div class="irow" data-issue="${encodeURIComponent(iss)}">
      <div class="ilabel${act?' act':''}">${iss}</div>
      <div class="itrack"><div class="ibar" style="width:${pct}%;background:${act?'#22d3a5':'#334155'}"></div></div>
      <div class="ict${act?' act':''}">${cnt}</div>
    </div>`;
  }).join('');
  document.getElementById('issueList').innerHTML=issHtml;
  document.getElementById('issueList').querySelectorAll('.irow').forEach(row=>{row.onclick=()=>setIssue(decodeURIComponent(row.dataset.issue));});
  document.getElementById('issueHint').style.display=activeIssue?'block':'none';

  // Donut
  const svg=document.getElementById('donut');
  const cx=50,cy=50,r=38,ir=24;
  let angle=-Math.PI/2;
  let paths='';
  POSITIONS.filter(p=>posCounts[p]).forEach(p=>{
    const pct=posCounts[p]/total;
    const s=angle;
    angle+=pct*2*Math.PI;
    const e=angle;
    const x1=cx+r*Math.cos(s),y1=cy+r*Math.sin(s);
    const x2=cx+r*Math.cos(e),y2=cy+r*Math.sin(e);
    const ix1=cx+ir*Math.cos(s),iy1=cy+ir*Math.sin(s);
    const ix2=cx+ir*Math.cos(e),iy2=cy+ir*Math.sin(e);
    const lg=(e-s)>Math.PI?1:0;
    paths+=`<path d="M ${ix1} ${iy1} A ${ir} ${ir} 0 ${lg} 1 ${ix2} ${iy2} L ${x2} ${y2} A ${r} ${r} 0 ${lg} 0 ${x1} ${y1} Z" fill="${PCOL[p]}" opacity="0.85"/>`;
  });
  svg.innerHTML=paths+`<circle cx="${cx}" cy="${cy}" r="14" fill="#0f172a"/><text x="${cx}" y="${cy-1}" text-anchor="middle" font-size="9" fill="#f8fafc" font-family="DM Sans" font-weight="500">${total}</text><text x="${cx}" y="${cy+8}" text-anchor="middle" font-size="6" fill="#475569" font-family="DM Mono">total</text>`;

  // Pos legend
  document.getElementById('posLegend').innerHTML=POSITIONS.filter(p=>posCounts[p]).map(p=>`
    <div class="prow"><div class="pdot-wrap"><div class="pdot" style="background:${PCOL[p]}"></div><span class="plabel">${p}</span></div><span class="pcount" style="color:${PCOL[p]}">${posCounts[p]}</span></div>`).join('');

  // Sector list
  const secSorted=SECTORS.filter(s=>secCounts[s]).sort((a,b)=>(secCounts[b]||0)-(secCounts[a]||0));
  const maxSec=Math.max(...secSorted.map(s=>secCounts[s]||0),1);
  document.getElementById('sectorList').innerHTML=secSorted.map((s,i)=>`
    <div class="srow" data-sec="${encodeURIComponent(s)}">
      <div class="sdot" style="background:${SCOL[s]}"></div>
      <div class="slabel${activeFilter===s?' act':''}">${s.replace('/Citizen','').replace('/NGO','').replace('/Development','').replace('/Industry','')}</div>
      <div class="scount" style="color:${activeFilter===s?SCOL[s]:'#334155'}">${secCounts[s]||0}</div>
      <div class="sbar-wrap"><div class="sbar" style="width:${(secCounts[s]||0)/maxSec*100}%;background:${SCOL[s]}"></div></div>
    </div>`).join('');

  // Table - card list for mobile
  const named=d.filter(r=>r.org!=='Individual respondent'&&r.org!=='Anonymous organisation');
  document.getElementById('tblCount').textContent=`${named.length} named orgs in view`;
  renderCoverage();
  document.getElementById('tblList').innerHTML=named.map(r=>`
    <div class="tbl-item">
      <div class="tbl-org">${r.org}</div>
      <div class="tbl-meta">
        <span class="badge" style="background:${SCOL[r.sector]}18;color:${SCOL[r.sector]}">${r.sector.replace('/Citizen','').replace('/NGO','').replace('/Development','').replace('/Industry','')}</span>
        <span class="badge" style="background:${PCOL[r.position]}18;color:${PCOL[r.position]}">${r.position}</span>
        <span style="font-size:10px;color:#475569;font-family:'DM Mono',monospace">${r.issues[0]}</span>
      </div>
      <div class="tbl-summary">${r.summary}</div>
    </div>`).join('');
  document.getElementById('sectorList').querySelectorAll('.srow').forEach(row=>{row.onclick=()=>setFilter(decodeURIComponent(row.dataset.sec));});
}
function setFilter(f){activeFilter=activeFilter===f&&f!=='all'?'all':f;render();}
function setIssue(i){activeIssue=activeIssue===i?null:i;render();}

render();
</script>
</body>
</html>