<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Accelerating Infrastructure — Consultation Intelligence · Easca Consulting</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{background:#0a0a0f;color:#e2e8f0;font-family:'DM Sans',system-ui,sans-serif;font-size:14px;line-height:1.5}

/* HEADER */
.hdr{border-bottom:1px solid #1e293b;padding:1.25rem 1rem}
.hdr-eyebrow{font-size:9px;letter-spacing:0.18em;color:#475569;font-family:'DM Mono',monospace;margin-bottom:3px;text-transform:uppercase}
.hdr-title{font-size:1rem;font-weight:500;color:#f8fafc;letter-spacing:-0.01em;line-height:1.3}
.hdr-sub{font-size:10px;color:#334155;margin-top:3px;font-family:'DM Mono',monospace;line-height:1.4}
.hdr-bottom{display:flex;justify-content:space-between;align-items:flex-end;margin-top:1rem;padding-top:1rem;border-top:1px solid #1e293b}
.hdr-num{font-size:2rem;font-weight:300;color:#22d3a5;letter-spacing:-0.04em;line-height:1}
.hdr-numlab{font-size:9px;color:#475569;font-family:'DM Mono',monospace;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:2px}
.hdr-numsub{font-size:9px;color:#334155;font-family:'DM Mono',monospace;margin-top:2px}

/* BODY */
.body{padding:1rem}

/* STATS */
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#1e293b;border-radius:8px;overflow:hidden;margin-bottom:1rem}@media(min-width:600px){.stats-grid{grid-template-columns:repeat(4,1fr)}}
.stat{background:#0f172a;padding:0.875rem 1rem}
.stat-label{font-size:9px;color:#475569;font-family:'DM Mono',monospace;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:3px}
.stat-val{font-size:1.5rem;font-weight:300;letter-spacing:-0.03em;line-height:1}
.stat-sub{font-size:9px;color:#334155;margin-top:2px;font-family:'DM Mono',monospace}

/* FILTERS */
.filters{display:flex;gap:4px;margin-bottom:1rem;flex-wrap:wrap}
.fb{font-size:10px;padding:5px 11px;border-radius:20px;border:1px solid #1e293b;background:transparent;color:#475569;cursor:pointer;font-family:'DM Mono',monospace;letter-spacing:0.04em;transition:all 0.15s;white-space:nowrap}
.fb.on{border-color:#22d3a5;background:rgba(34,211,165,0.08);color:#22d3a5}

/* CHARTS ROW */
.charts-row{display:block}
.charts-row{display:flex;flex-direction:column;gap:1rem;margin-bottom:1rem}@media(min-width:768px){.charts-row{flex-direction:row;align-items:stretch}.charts-row>div:first-child{flex:1;min-width:0}.right-col{flex:1;min-width:0;display:flex;flex-direction:column;gap:1rem}.right-col .card{flex:1}}
/* CARD */
.card{background:#0f172a;border:1px solid #1e293b;border-radius:10px;padding:1rem;margin-bottom:1rem}
.card-label{font-size:9px;letter-spacing:0.15em;color:#475569;font-family:'DM Mono',monospace;text-transform:uppercase;margin-bottom:0.875rem}

/* ISSUES */
.irow{display:flex;align-items:center;gap:8px;margin-bottom:8px;cursor:pointer;padding:2px 0}
.ilabel{flex:0 0 120px;font-size:10px;color:#64748b;font-family:'DM Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:color 0.15s}@media(min-width:600px){.ilabel{flex:0 0 180px}}
.ilabel.act{color:#f8fafc}
.itrack{flex:1;height:3px;background:#1e293b;border-radius:1px;overflow:hidden}
.ibar{height:100%;border-radius:1px;transition:all 0.3s ease}
.ict{flex:0 0 24px;text-align:right;font-size:10px;color:#334155;font-family:'DM Mono',monospace;transition:color 0.15s}
.ict.act{color:#22d3a5}

/* POSITION */
.pos-wrap{display:flex;gap:1rem;align-items:center}
.prow{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.pdot-wrap{display:flex;align-items:center;gap:6px}
.pdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.plabel{font-size:11px;color:#64748b;font-family:'DM Mono',monospace}
.pcount{font-size:11px;font-family:'DM Mono',monospace}

/* SECTOR */
.srow{display:flex;align-items:center;gap:8px;margin-bottom:7px;cursor:pointer;padding:2px 0}
.sdot{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.slabel{flex:1;font-size:11px;color:#475569;font-family:'DM Mono',monospace;transition:color 0.15s}
.slabel.act{color:#f8fafc}
.scount{font-size:10px;font-family:'DM Mono',monospace;color:#334155;min-width:22px;text-align:right}
.sbar-wrap{width:40px;height:2px;background:#1e293b;border-radius:1px}
.sbar{height:100%;border-radius:1px;opacity:0.5}

/* INSIGHTS */
.insights{display:grid;grid-template-columns:1fr;gap:1px;background:#1e293b;border-radius:10px;overflow:hidden;margin-bottom:1rem}
@media(min-width:480px){.insights{grid-template-columns:repeat(3,1fr)}}
.insight{background:#0a0a0f;padding:1.1rem 1rem}
.ins-num{font-size:2rem;font-weight:300;letter-spacing:-0.04em;line-height:1;margin-bottom:3px}
.ins-label{font-size:12px;color:#94a3b8;margin-bottom:2px}
.ins-sub{font-size:10px;color:#334155;font-family:'DM Mono',monospace;margin-bottom:6px}
.ins-note{font-size:10px;color:#475569;font-family:'DM Mono',monospace;border-top:1px solid #1e293b;padding-top:7px}

/* TABLE */
.tbl-card{background:#0f172a;border:1px solid #1e293b;border-radius:10px;overflow:hidden;margin-bottom:1rem}
.tbl-hdr{padding:0.75rem 1rem;border-bottom:1px solid #1e293b;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:4px}
.tbl-hdr-label{font-size:9px;letter-spacing:0.15em;color:#475569;font-family:'DM Mono',monospace;text-transform:uppercase}
.tbl-hdr-sub{font-size:9px;color:#334155;font-family:'DM Mono',monospace}

/* Mobile table: card list instead */
.tbl-list{display:flex;flex-direction:column}
.tbl-item{padding:0.75rem 1rem;border-bottom:1px solid #0f172a;background:#0f172a;transition:background 0.1s}
.tbl-item:hover{background:#111827}
.tbl-item:last-child{border-bottom:none}
.tbl-org{font-size:12px;font-weight:500;color:#e2e8f0;margin-bottom:4px}
.tbl-meta{display:flex;gap:6px;flex-wrap:wrap;align-items:center;margin-bottom:4px}
.badge{font-size:9px;padding:2px 7px;border-radius:10px;font-family:'DM Mono',monospace;display:inline-block;white-space:nowrap}
.tbl-summary{font-size:11px;color:#475569;line-height:1.4}

/* FOOTER */
.footer{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;flex-wrap:wrap;padding-bottom:1rem}
.footer-text{font-size:9px;color:#334155;font-family:'DM Mono',monospace;line-height:1.5;flex:1}
.footer-brand{font-size:9px;color:#22d3a5;font-family:'DM Mono',monospace;letter-spacing:0.1em;white-space:nowrap}

/* Active issue hint */
.issue-hint{font-size:9px;color:#22d3a5;font-family:'DM Mono',monospace;margin-top:6px;letter-spacing:0.05em}

@media(min-width:768px){
  .body{padding:1.5rem 2rem}
  .hdr{padding:1.5rem 2rem}
  .hdr-title{font-size:1.3rem}
  .hdr-num{font-size:2.8rem}
  .stat{padding:1.25rem 1.5rem}
  .stat-val{font-size:2rem}
  .stat-label{font-size:11px}
  .stat-sub{font-size:11px}
  .card-label{font-size:11px}
  .ilabel{flex:0 0 200px;font-size:11px}
  .ict{font-size:11px}
  .itrack{height:4px}
  .slabel{font-size:12px}
  .tbl-org{font-size:13px}
  .tbl-summary{font-size:12px}
  .ins-num{font-size:2.8rem}
  .ins-label{font-size:13px}
  .ins-sub{font-size:11px}
  .ins-note{font-size:11px}
  .filters{gap:6px}
  .fb{font-size:11px;padding:5px 14px}
  .hdr-eyebrow{font-size:11px}
  .hdr-sub{font-size:12px}
  .card{padding:1.5rem}
  .insights{margin-bottom:1.5rem}
  .insight{padding:1.5rem}
}
@media(min-width:1024px){
  .body{padding:1.5rem 3rem}
  .hdr{padding:1.5rem 3rem}
}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-eyebrow">Easca Consulting · Consultation Intelligence</div>
  <div class="hdr-title">Accelerating Infrastructure: Public Consultation</div>
  <div class="hdr-sub">Dept. of Public Expenditure, Infrastructure, Public Service Reform &amp; Digitalisation · Ireland · 2025</div>
  <div class="hdr-bottom">
    <div>
      <div class="hdr-numlab">Submissions analysed</div>
      <div class="hdr-num" id="totalNum">165</div>
      <div class="hdr-numsub">165 total public submissions</div>
    </div>
    <div style="text-align:right">
      <div class="hdr-numlab">Active filter</div>
      <div style="font-size:11px;color:#22d3a5;font-family:'DM Mono',monospace;margin-top:2px" id="activeLabel">All submissions</div>
    </div>
  </div>
</div>

<div class="body">
  <div class="stats-grid" id="statsGrid"></div>
  <div class="filters" id="filters"></div>

  <div class="charts-row">
  <div class="card" style="margin-bottom:0">
    <div class="card-label">Issues raised — tap to filter</div>
    <div id="issueList"></div>
    <div id="issueHint" class="issue-hint" style="display:none">Tap again to clear filter</div>
  </div>
  <div class="right-col">
    <div class="card" style="margin-bottom:0">
      <div class="card-label">Position distribution</div>
      <div class="pos-wrap">
        <svg id="donut" viewBox="0 0 100 100" style="flex-shrink:0;width:clamp(90px,10vw,130px);height:clamp(90px,10vw,130px)"></svg>
        <div id="posLegend" style="flex:1"></div>
      </div>
    </div>
    <div class="card" style="margin-bottom:0;flex:1">
      <div class="card-label">By sector — tap to filter</div>
      <div id="sectorList"></div>
    </div>
  </div>
</div>

  <div class="insights">
    <div class="insight">
      <div class="ins-num" style="color:#f87171">3</div>
      <div class="ins-label">organised community groups</div>
      <div class="ins-sub">out of 166 public submissions</div>
      <div class="ins-note">Midleton floods · S2S cycleway · homebuyers</div>
    </div>
    <div class="insight">
      <div class="ins-num" style="color:#fb923c">22</div>
      <div class="ins-label">independently raised capacity gaps</div>
      <div class="ins-sub">Arup · Mott Mac · CIF · Engineers Ireland…</div>
      <div class="ins-note">Not a named pillar in the Action Plan</div>
    </div>
    <div class="insight">
      <div class="ins-num" style="color:#22d3a5">58</div>
      <div class="ins-label">submissions: conditional support</div>
      <div class="ins-sub">the largest single position group</div>
      <div class="ins-note">TII · NTA · EirGrid · ESB · Uisce Éireann · DCC</div>
    </div>
  </div>

  
  <div class="card" style="margin-bottom:1rem">
    <div class="card-label">Submissions vs Action Plan — what was addressed?</div>
    <div style="margin-bottom:10px;font-size:10px;color:#475569;font-family:'DM Mono',monospace">30 actions across 4 pillars. Issues raised in submissions mapped to coverage.</div>
    <div id="coverageList"></div>
    <div style="margin-top:10px;padding-top:10px;border-top:1px solid #1e293b;font-size:10px;color:#334155;font-family:'DM Mono',monospace">
      Source: Accelerating Infrastructure Report and Action Plan, December 2025
    </div>
  </div>
<div class="tbl-card">
    <div class="tbl-hdr">
      <div class="tbl-hdr-label">Named respondents</div>
      <div class="tbl-hdr-sub" id="tblCount"></div>
    </div>
    <div class="tbl-list" id="tblList"></div>
  </div>

  <div class="footer">
    <div class="footer-text">Source: gov.ie · 166 form submissions + 67 supplementary documents · Structured analysis by Easca Consulting · eascaconsulting.com</div>
    <div class="footer-brand">EASCA</div>
  </div>
</div>

<script>
const ALL=[{"n":1,"org":"Anonymous organisation","type":"Organisation","sector":"Business/Industry","issues":["Planning delays","Regulatory complexity","Funding/investment","Delivery timelines"],"position":"Conditional support","summary":"Supports reform but highlights risk-return tensions in PPPs"},{"n":2,"org":"Anonymous organisation","type":"Organisation","sector":"Individual/Citizen","issues":["Agency coordination","Delivery timelines"],"position":"Conditional support","summary":"Wants unified governance body for infrastructure"},{"n":3,"org":"Anonymous organisation","type":"Organisation","sector":"Professional Services","issues":["Delivery timelines","Regulatory complexity","Agency coordination","Climate/sustainability"],"position":"Supportive","summary":"Broadly positive on reform direction, stresses long-term planning"},{"n":4,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines","Agency coordination"],"position":"Raising concerns","summary":"Frustrated by infrastructure failures affecting public services"},{"n":5,"org":"Edelman Ireland","type":"Organisation","sector":"Professional Services","issues":["Public consultation","Community engagement","Delivery timelines"],"position":"Conditional support","summary":"Supports acceleration but calls for stronger public engagement"},{"n":6,"org":"HISCo","type":"Organisation","sector":"Construction/Development","issues":["Agency coordination","Grid connections","Funding/investment","Housing delivery"],"position":"Raising concerns","summary":"No formal coordination between delivery agents; systemic gap"},{"n":7,"org":"HISCo","type":"Organisation","sector":"Construction/Development","issues":["Agency coordination","Housing delivery","Grid connections","Delivery timelines"],"position":"Raising concerns","summary":"Calls for integrated delivery model across state agencies"},{"n":8,"org":"HISCo","type":"Organisation","sector":"Construction/Development","issues":["Agency coordination","Funding/investment","Housing delivery"],"position":"Raising concerns","summary":"Follow-on submission: state agencies not working together"},{"n":9,"org":"Trifecta Ireland","type":"Organisation","sector":"Energy","issues":["Grid connections","Delivery timelines","Regulatory complexity","Legal reform"],"position":"Raising concerns","summary":"Ireland outlier in Europe for slow electricity infrastructure"},{"n":10,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Regulatory complexity","Agency coordination","Delivery timelines"],"position":"Conditional support","summary":"Right structures exist but post-2008 capacity decimated"},{"n":11,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Legal reform","Delivery timelines"],"position":"Raising concerns","summary":"Flood relief schemes blocked by ministerial consent bottleneck"},{"n":12,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines","Agency coordination"],"position":"Raising concerns","summary":"System too slow; multiple veto points causing gridlock"},{"n":13,"org":"Northern & Western Regional Assembly","type":"Organisation","sector":"Local Government","issues":["Planning delays","Delivery timelines","Funding/investment","Agency coordination"],"position":"Raising concerns","summary":"Appraisal processes too onerous; regional investment needed"},{"n":14,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"General frustration with pace of infrastructure delivery"},{"n":15,"org":"Laois County Council","type":"Organisation","sector":"Local Government","issues":["Agency coordination","Funding/investment","Planning delays","Capacity/skills"],"position":"Conditional support","summary":"Plan-led but needs better national-local coordination"},{"n":16,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"Systemic delays prevent timely infrastructure delivery"},{"n":17,"org":"An Taisce","type":"Organisation","sector":"Environmental/NGO","issues":["Environmental assessment","Public consultation","Legal reform","Climate/sustainability"],"position":"Mixed","summary":"Reform welcome but must not undermine environmental safeguards"},{"n":18,"org":"COWI UK & Ireland","type":"Organisation","sector":"Professional Services","issues":["Agency coordination","Delivery timelines","Capacity/skills","Planning delays"],"position":"Conditional support","summary":"Fragmentation across departments causing delays; needs central delivery unit"},{"n":19,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Delivery timelines","Community engagement"],"position":"Raising concerns","summary":"Local infrastructure failures during storm events"},{"n":20,"org":"Wind Energy Ireland","type":"Organisation","sector":"Energy","issues":["Planning delays","Grid connections","Legal reform","Environmental assessment"],"position":"Conditional support","summary":"Detailed submission: planning and grid key barriers to renewables"},{"n":21,"org":"Dublin City Council","type":"Organisation","sector":"Local Government","issues":["Grid connections","Planning delays","Agency coordination","Housing delivery"],"position":"Conditional support","summary":"Ambitious targets undermined by grid and planning constraints"},{"n":22,"org":"Shannon Foynes Port Company","type":"Organisation","sector":"Transport","issues":["Planning delays","Funding/investment","Delivery timelines","Regulatory complexity"],"position":"Conditional support","summary":"Port infrastructure adequate historically but reform needed"},{"n":23,"org":"National Transport Authority","type":"Organisation","sector":"Transport","issues":["Planning delays","Agency coordination","Delivery timelines","Land/CPO"],"position":"Conditional support","summary":"Detailed NTA submission attached; systemic reform required"},{"n":24,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"System too slow across all infrastructure types"},{"n":25,"org":"Transport Infrastructure Ireland","type":"Organisation","sector":"Transport","issues":["Planning delays","Legal reform","Land/CPO","Delivery timelines"],"position":"Raising concerns","summary":"Delivery increasingly difficult; TII notes rising complexity"},{"n":26,"org":"Cloud Infrastructure Ireland","type":"Organisation","sector":"Business/Industry","issues":["Grid connections","Planning delays","Regulatory complexity","Delivery timelines"],"position":"Raising concerns","summary":"Data centre sector blocked by grid and planning constraints"},{"n":27,"org":"Bord Gáis Energy","type":"Organisation","sector":"Energy","issues":["Regulatory complexity","Agency coordination","Planning delays","Funding/investment"],"position":"Conditional support","summary":"Lacks integrated holistic planning framework for networks"},{"n":28,"org":"Anonymous organisation","type":"Organisation","sector":"Individual/Citizen","issues":["Delivery timelines"],"position":"Raising concerns","summary":"Empty or minimal submission"},{"n":29,"org":"Mayo County Council","type":"Organisation","sector":"Local Government","issues":["Agency coordination","Funding/investment","Planning delays","Delivery timelines"],"position":"Conditional support","summary":"Coordinated strategic planning needed; regions underserved"},{"n":30,"org":"Anonymous organisation","type":"Organisation","sector":"Individual/Citizen","issues":["Delivery timelines"],"position":"Raising concerns","summary":"Minimal submission"},{"n":31,"org":"Turner & Townsend","type":"Organisation","sector":"Professional Services","issues":["Planning delays","Capacity/skills","Procurement","Delivery timelines"],"position":"Conditional support","summary":"Successive governments failed to deliver; systemic reform needed"},{"n":32,"org":"Turner & Townsend","type":"Organisation","sector":"Professional Services","issues":["Planning delays","Capacity/skills","Procurement","Delivery timelines"],"position":"Conditional support","summary":"Duplicate submission; same key concerns"},{"n":33,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"Infrastructure delays harming communities"},{"n":34,"org":"Individual (Engineer, Local Gov)","type":"Individual","sector":"Individual/Citizen","issues":["Capacity/skills","Planning delays","Agency coordination","Procurement"],"position":"Raising concerns","summary":"25 years experience: capacity and coordination are the core problem"},{"n":35,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"Delivery too slow across all sectors"},{"n":36,"org":"ULI Ireland","type":"Organisation","sector":"Business/Industry","issues":["Regulatory complexity","Funding/investment","Investor confidence","Delivery timelines"],"position":"Conditional support","summary":"Competitiveness at risk; reform urgent but must be balanced"},{"n":37,"org":"Jacobs Ireland","type":"Organisation","sector":"Professional Services","issues":["Planning delays","Capacity/skills","Procurement","Delivery timelines"],"position":"Conditional support","summary":"Full response attached; planning and capacity key barriers"},{"n":38,"org":"CIEEM","type":"Organisation","sector":"Environmental/NGO","issues":["Environmental assessment","Public consultation","Climate/sustainability","Legal reform"],"position":"Mixed","summary":"Reform must not compromise ecological and environmental standards"},{"n":39,"org":"Art Data Centres","type":"Organisation","sector":"Business/Industry","issues":["Grid connections","Regulatory complexity","Delivery timelines"],"position":"Raising concerns","summary":"Fibre, gas, electricity infrastructure delays since 2017"},{"n":40,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"Infrastructure delays unacceptable"},{"n":41,"org":"Chambers Ireland","type":"Organisation","sector":"Business/Industry","issues":["Planning delays","Regulatory complexity","Delivery timelines","Investor confidence"],"position":"Conditional support","summary":"Full submission attached; urgent reform needed for competitiveness"},{"n":42,"org":"Anonymous organisation","type":"Organisation","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines","Agency coordination"],"position":"Raising concerns","summary":"Systemic barriers preventing delivery"},{"n":43,"org":"Anonymous organisation","type":"Organisation","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summary":"Delivery system needs reform"},{"n":44,"org":"Bremore Ireland Port","type":"Organisation","sector":"Transport","issues":["Planning delays","Land/CPO","Funding/investment","Delivery timelines"],"position":"Conditional support","summary":"Port development blocked by planning and land access issues"},{"n":45,"org":"Keeper Solutions","type":"Organisation","sector":"Professional Services","issues":["Planning delays","Regulatory complexity","Delivery timelines","Capacity/skills"],"position":"Conditional support","summary":"Ambitious plans held back by complex rules and limited capacity"},{"n":46,"org":"Individual respondent","type":"Individual","sector":"Individual/Citizen","issues":["Planning delays","Delivery timelines"],"position":"Raising concerns","summ